# regular expression library
import re

## define a useful function to parse a range of cells
def parse_cell_range(cell_range):
    match = re.match(r'([A-Z]+)(\d+):([A-Z]+)(\d+)', cell_range)
    if match:
        col1, row1, col2, row2 = match.groups()
        return {"start_col": col1, "start_row": int(row1), "end_col": col2, "end_row": int(row2)}
    else:
        raise ValueError("Invalid format. Expected format: 'A10:B12'.")

## define a useful function to load data from an Excel spreadsheet
def load_spreadsheet(file_path, sheet, data_range):
    # Load the workbook
    xl = pd.ExcelFile(file_path, engine='openpyxl')

    # Read data from the specified ranges
    data = {} # Initialise empty dictionary
    for variable_name, cell_range_string in data_range.items():
        # Parse cell start and end from string
        cell_range_dict = parse_cell_range(cell_range_string)
        columns   = '%s:%s' % (cell_range_dict['start_col'], cell_range_dict['end_col'])
        n_rows    = cell_range_dict['end_row']-cell_range_dict['start_row']+1

        # Read data from the specified ranges
        data[variable_name] = pd.read_excel(xl, \
            sheet_name=sheet, \
            usecols=columns, \
            skiprows=cell_range_dict['start_row']-2, \
            nrows=n_rows).values.flatten()
        
        # Convert single element arrays to scalar
        if len(data[variable_name]) == 1:
            data[variable_name] = data[variable_name].item()
        
    return data
        

